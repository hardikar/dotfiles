source ~/.bashrc
export PATH="/usr/local/opt/apr/bin:$PATH"
export PATH="/usr/local/opt/apr-util/bin:$PATH"


# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/shardikar/Downloads/google-cloud-sdk/path.bash.inc' ]; then . '/Users/shardikar/Downloads/google-cloud-sdk/path.bash.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/shardikar/Downloads/google-cloud-sdk/completion.bash.inc' ]; then . '/Users/shardikar/Downloads/google-cloud-sdk/completion.bash.inc'; fi
